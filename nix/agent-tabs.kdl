// Installed by the zellij-agent-tabs home-manager module. Run: zellij -l agent-tabs
// See docs/config-example.kdl in the repo for every option, annotated.
layout {
    pane split_direction="vertical" {
        pane size=26 borderless=true {
            plugin location="file:~/.config/zellij/plugins/zellij-agent-tabs.wasm" {
                tab_height 3
                anim_interval_ms 400
                state_priority "error waiting working done idle"
            }
        }
        pane focus=true
    }
    pane size=1 borderless=true {
        plugin location="zellij:status-bar"
    }
}
